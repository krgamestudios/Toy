//make sure it works with multiple repititions

//-------------------------

//test break
while (true) {
	break;
	assert false, "break failed";
}

//test continue
var flag1: bool = true;
while (flag1) {
	flag1 = false;
	continue;
	assert false, "continue failed";
}

print "done";

