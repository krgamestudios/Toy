//1-D table
var a = ["alpha": 1, "beta": 2, "gamma": 3];
a["beta"] = 6;

print a;
assert a == ["alpha": 1, "beta": 6, "gamma": 3], "1-D tables failed";

//WONTFIX: Nested tables cause an issue under very specific circumstances: run under GDB, in verbose mode, only in github's CI runner. The reason is unclear.

//nested
var b = [
	"outer": ["inner": true],
	"alpha": 1,
	"beta": 2,
	"gamma": 3
];

print b;
assert b == ["alpha": 1, "beta": 2, "gamma": 3, "outer": ["inner": true]], "nested tables failed";

//test empty tables
var empty = [:];

print empty;
assert empty == [:], "empty tables failed";

//test trailing commas
var trailing = [
	"alpha":1,
	"beta":2,
	"gamma":3,
];

print trailing;
assert trailing == ["alpha": 1, "beta": 2, "gamma": 3], "trailing tables failed";