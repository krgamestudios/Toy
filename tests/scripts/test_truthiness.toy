//booleans
{
	var value: Bool = true;

	if (value) {
		print "boolean";
	}
	else {
		assert false, "boolean";
	}
}

{
	var value: Bool = false;

	if (value) {
		assert false, "boolean";
	}
	else {
		print "boolean";
	}
}

//integers
{
	var value: Int = 42;

	if (value) {
		print "integer";
	}
	else {
		assert false, "integer";
	}
}

{
	var value: Int = 0;

	if (value) {
		assert false, "integer";
	}
	else {
		print "integer";
	}
}

//floats
{
	var value: Float = 42.8891;

	if (value) {
		print "float";
	}
	else {
		assert false, "float";
	}
}

{
	var value: Float = 0;

	if (value) {
		assert false, "float";
	}
	else {
		print "float";
	}
}

//everything else
{
	var value: String = "foobar";

	if (value) {
		print "string";
	}
	else {
		assert false, "string";
	}
}