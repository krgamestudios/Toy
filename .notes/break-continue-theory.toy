while (a) { //stored in an array
	while (b) { //stored in an array
		while(c) { //stored in an array

			//just peek at the array's top
			continue;

			//these are stored in a second array
			break;
			break;
			break;
		} //breaks are updated here

		//but what about these?
		break;
		break;
		break;
	}
}
