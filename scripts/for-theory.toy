//example of a `range` function
fn range(limit: Int) {
	var counter: Int = 0;

	fn next() {
		if (counter >= limit) {
			return null;
		}
		else return counter++;
	}

	return next;
}

var next = range(10);


fn log(x) {
	if (x == null) return;
	print x;
}

while (true) {
	log(next());
}