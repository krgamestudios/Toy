//advent of code thingy
var arr = [
	3,   4,
	4,   3,
	2,   5,
	1,   3,
	3,   9,
	3 ,  3
];

var total = 0;
var counter = 0;

while (counter < arr.length) {
	var difference = arr[counter] - arr[counter+1];

	if (difference < 0) {
		difference = -difference;
	}

	total += difference;

	counter += 2;
}

print difference;

